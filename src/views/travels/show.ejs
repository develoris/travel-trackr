<!DOCTYPE html>
<html lang="it">
<head>
  <%- include("../partials/head", { title: trip.title }) %>
</head>
<body class="d-flex flex-column min-vh-100">
  <%- include("../partials/navbar", { user }) %>

  <main class="flex-grow-1 py-4 py-md-5">
    <div class="container">
      <%- include("../partials/flash") %>

      <!-- Header compatto: senza hero per guadagnare spazio verticale -->
      <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
        <div>
          <a href="/users/app/travels" class="text-decoration-none small">&larr; Torna ai viaggi</a>
          <h1 class="h3 fw-bold mb-1 mt-2"><%= trip.title %></h1>
          <p class="text-muted mb-0"><%= trip.locationSummary || 'Localita da definire' %></p>
        </div>
        <div class="d-flex gap-2">
          <button class="btn btn-outline-dark btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#editTripPanel" aria-expanded="false">Modifica viaggio</button>
          <form action="/users/app/travels/<%= trip._id %>/delete" method="POST" onsubmit="return confirm('Eliminare il viaggio?');">
            <button class="btn btn-outline-danger btn-sm" type="submit">Elimina</button>
          </form>
        </div>
      </div>

      <!-- Stats -->
      <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
          <div class="card h-100"><div class="card-body"><div class="text-muted small">Durata</div><div class="fw-semibold small"><%= new Date(trip.startDate).toLocaleDateString('it-IT') %> - <%= new Date(trip.endDate).toLocaleDateString('it-IT') %></div></div></div>
        </div>
        <div class="col-6 col-md-3">
          <div class="card h-100"><div class="card-body"><div class="text-muted small">Tappe (giorni)</div><div class="fw-semibold"><%= trip.stats?.daysCount || 0 %></div></div></div>
        </div>
        <div class="col-6 col-md-3">
          <div class="card h-100"><div class="card-body"><div class="text-muted small">Attivita</div><div class="fw-semibold"><%= trip.stats?.activitiesCount || trip.stats?.stagesCount || 0 %></div></div></div>
        </div>
        <div class="col-6 col-md-3">
          <div class="card h-100"><div class="card-body"><div class="text-muted small">Spesa totale</div><div class="fw-semibold">EUR <%= Number(totalSpent || 0).toFixed(2) %></div></div></div>
        </div>
      </div>

      <!-- Descrizione generale del viaggio -->
      <div class="card mb-4">
        <div class="card-body">
          <h2 class="h6 mb-2">Descrizione generale</h2>
          <p class="mb-2"><%= trip.description || 'Nessuna descrizione generale inserita.' %></p>
          <% if (trip.notes) { %>
            <p class="text-muted small mb-0"><strong>Note:</strong> <%= trip.notes %></p>
          <% } %>
        </div>
      </div>

      <!-- Edit trip collapse -->
      <div class="collapse mb-4" id="editTripPanel">
        <div class="card">
          <div class="card-body">
            <h2 class="h5 mb-3">Modifica viaggio</h2>
            <form action="/users/app/travels/<%= trip._id %>/update" method="POST" class="row g-2">
              <div class="col-12 col-lg-6"><label class="form-label small text-muted mb-1">Titolo</label><input class="form-control" name="title" value="<%= trip.title %>" required /></div>
              <div class="col-12 col-lg-3"><label class="form-label small text-muted mb-1">Categoria</label><select class="form-select" name="category"><% ['escursione','trekking','visita','vacanza','roadtrip','altro'].forEach((c) => { %><option value="<%= c %>" <%= trip.category === c ? 'selected' : '' %>><%= c %></option><% }) %></select></div>
              <div class="col-12 col-lg-3"><label class="form-label small text-muted mb-1">Stato</label><select class="form-select" name="status"><% ['planned','ongoing','completed','cancelled'].forEach((s) => { %><option value="<%= s %>" <%= trip.status === s ? 'selected' : '' %>><%= s %></option><% }) %></select></div>
              <div class="col-12 col-md-6"><label class="form-label small text-muted mb-1">Data inizio</label><input class="form-control" type="date" name="startDate" value="<%= new Date(trip.startDate).toISOString().slice(0,10) %>" /></div>
              <div class="col-12 col-md-6"><label class="form-label small text-muted mb-1">Data fine</label><input class="form-control" type="date" name="endDate" value="<%= new Date(trip.endDate).toISOString().slice(0,10) %>" /></div>
              <div class="col-12"><label class="form-label small text-muted mb-1">Localita principali</label><input class="form-control" name="locationSummary" value="<%= trip.locationSummary || '' %>" /></div>
              <div class="col-12 col-lg-6"><label class="form-label small text-muted mb-1">Descrizione</label><textarea class="form-control" name="description" rows="3"><%= trip.description || '' %></textarea></div>
              <div class="col-12 col-lg-6"><label class="form-label small text-muted mb-1">Note</label><textarea class="form-control" name="notes" rows="3"><%= trip.notes || '' %></textarea></div>
              <div class="col-12 d-flex justify-content-end"><button class="btn btn-dark" type="submit">Salva modifiche</button></div>
            </form>
          </div>
        </div>
      </div>

      <!-- Section header -->
      <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
        <h2 class="h5 mb-0">Tappe e attivita</h2>
        <div class="d-flex gap-2">
          <button class="btn btn-outline-secondary btn-sm" id="btnCollapseAll" type="button">Chiudi tutte</button>
          <button class="btn btn-outline-secondary btn-sm" id="btnExpandAll" type="button">Esplodi tutte</button>
          <button class="btn btn-dark btn-sm" type="button" data-bs-toggle="modal" data-bs-target="#newActivityModal">+ Nuova attivita</button>
        </div>
      </div>

      <!-- Empty state -->
      <% if (!dayGroups || dayGroups.length === 0) { %>
        <div class="card text-center py-5">
          <div class="card-body">
            <i class="bi bi-calendar-x text-secondary" style="font-size:2rem;"></i>
            <h3 class="h5 mt-3">Nessuna attivita ancora</h3>
            <p class="text-muted mb-3">Aggiungi la prima attivita con il pulsante in alto.</p>
            <button class="btn btn-dark btn-sm" data-bs-toggle="modal" data-bs-target="#newActivityModal">+ Nuova attivita</button>
          </div>
        </div>
      <% } else { %>

      <!-- Accordion tappe -->
      <div class="accordion" id="daysAccordion">
        <% dayGroups.forEach((group, idx) => { %>
          <% const dayId = group.dayNumber === Number.MAX_SAFE_INTEGER ? 'unset' : group.dayNumber; %>
          <% const isOpen = dayGroups.length === 1 || idx === 0; %>
          <div class="accordion-item">
            <h2 class="accordion-header">
              <button class="accordion-button <%= isOpen ? '' : 'collapsed' %>" type="button" data-bs-toggle="collapse" data-bs-target="#collapseDay<%= dayId %>" aria-expanded="<%= isOpen %>">
                <% if (group.dayNumber === Number.MAX_SAFE_INTEGER) { %>
                  <span class="fw-semibold">Attivita senza tappa</span>
                <% } else { %>
                  <span class="fw-semibold">Tappa <%= group.dayNumber %></span>
                <% } %>
                <span class="badge bg-secondary ms-2"><%= group.activities.length %></span>
              </button>
            </h2>
            <div id="collapseDay<%= dayId %>" class="accordion-collapse collapse <%= isOpen ? 'show' : '' %>">
              <div class="accordion-body">
                <div class="vstack gap-3">
                  <% group.activities.forEach((stage) => { %>
                    <div class="card">
                      <div class="card-body">
                        <div class="d-flex flex-wrap align-items-start justify-content-between gap-2 mb-2">
                          <div>
                            <h3 class="h6 mb-1"><%= stage.title %></h3>
                            <div class="text-muted small">
                              <span class="badge text-bg-secondary me-1"><%= stage.activityType %></span>
                              <% if (stage.startAt) { %><span><i class="bi bi-clock me-1"></i><%= new Date(stage.startAt).toLocaleTimeString('it-IT', { hour: '2-digit', minute: '2-digit' }) %></span><% } %>
                              <% if (stage.location) { %><span class="ms-2"><i class="bi bi-geo-alt me-1"></i><%= stage.location %></span><% } %>
                            </div>
                          </div>
                          <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#editActivity<%= stage._id %>" aria-expanded="false">Modifica</button>
                        </div>
                        <% if (stage.description) { %><p class="text-muted small mb-3"><%= stage.description %></p><% } %>

                        <!-- Edit activity (collapse) -->
                        <div class="collapse mb-3" id="editActivity<%= stage._id %>">
                          <div class="card card-body bg-light border-0">
                            <form action="/users/app/travels/<%= trip._id %>/stages/<%= stage._id %>/update" method="POST" class="row g-2">
                              <div class="col-12 col-md-7"><label class="form-label small text-muted mb-1">Titolo</label><input class="form-control form-control-sm" name="title" value="<%= stage.title %>" required /></div>
                              <div class="col-12 col-md-5"><label class="form-label small text-muted mb-1">Tipo</label><select class="form-select form-select-sm" name="activityType"><% ['trek','visita','trasferimento','food','relax','outdoor','altro'].forEach((type) => { %><option value="<%= type %>" <%= stage.activityType === type ? 'selected' : '' %>><%= type %></option><% }) %></select></div>
                              <div class="col-12 col-md-6"><label class="form-label small text-muted mb-1">Tappa (giorno)</label><input class="form-control form-control-sm" type="number" min="1" step="1" name="dayNumber" value="<%= stage.dayNumber || '' %>" /></div>
                              <div class="col-12 col-md-6"><label class="form-label small text-muted mb-1">Orario inizio</label><input class="form-control form-control-sm" type="time" name="startTime" value="<%= stage.startAt ? new Date(stage.startAt).toISOString().slice(11,16) : '' %>" /></div>
                              <div class="col-12"><label class="form-label small text-muted mb-1">Luogo</label><input class="form-control form-control-sm" name="location" value="<%= stage.location || '' %>" /></div>
                              <div class="col-12"><label class="form-label small text-muted mb-1">Descrizione</label><textarea class="form-control form-control-sm" name="description" rows="2"><%= stage.description || '' %></textarea></div>
                              <div class="col-12 d-flex justify-content-end gap-2">
                                <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#editActivity<%= stage._id %>">Annulla</button>
                                <button class="btn btn-dark btn-sm" type="submit">Salva</button>
                              </div>
                            </form>
                          </div>
                        </div>

                        <!-- Expenses -->
                        <div>
                          <p class="small fw-semibold mb-1">Spese</p>
                          <% if (!stage.expenses || stage.expenses.length === 0) { %>
                            <p class="text-muted small mb-2">Nessuna spesa.</p>
                          <% } else { %>
                            <ul class="list-group list-group-flush mb-2">
                              <% stage.expenses.forEach((expense) => { %>
                                <li class="list-group-item px-0 py-1 d-flex justify-content-between align-items-center">
                                  <span class="small"><strong><%= expense.title %></strong> <span class="text-muted">(<%= expense.category %>)</span></span>
                                  <span class="small">EUR <%= Number(expense.amount || 0).toFixed(2) %></span>
                                </li>
                              <% }) %>
                            </ul>
                          <% } %>
                          <form action="/users/app/travels/<%= trip._id %>/stages/<%= stage._id %>/expenses" method="POST" class="row g-2">
                            <div class="col-md-5"><input class="form-control form-control-sm" name="title" placeholder="Spesa" required /></div>
                            <div class="col-md-3"><input class="form-control form-control-sm" name="amount" type="number" step="0.01" min="0" placeholder="0.00" required /></div>
                            <div class="col-md-4"><select class="form-select form-select-sm" name="category"><option value="trasporto">Trasporto</option><option value="alloggio">Alloggio</option><option value="cibo">Cibo</option><option value="attivita">Attivita</option><option value="attrezzatura">Attrezzatura</option><option value="altro">Altro</option></select></div>
                            <div class="col-12"><button class="btn btn-outline-dark btn-sm" type="submit">Aggiungi spesa</button></div>
                          </form>
                        </div>

                      </div>
                    </div>
                  <% }) %>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>

      <% } %>
    </div>
  </main>

  <footer class="text-center text-muted py-3 small border-top mt-auto">&copy; <%= new Date().getFullYear() %> Travel Trackr</footer>

  <!-- Modali separate in partial dedicato -->
  <%- include("./partials/new-activity-modal", { trip, dayOptions }) %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    (function () {
      // Radio sync for modal
      const syncModalDayMode = () => {
        const existing = document.getElementById('modalDayModeExisting');
        const existingWrap = document.getElementById('modalExistingDayWrap');
        const newWrap = document.getElementById('modalNewDayWrap');
        if (!existing || !existingWrap || !newWrap) return;
        existingWrap.style.display = existing.checked ? '' : 'none';
        newWrap.style.display = existing.checked ? 'none' : '';
      };
      document.getElementById('modalDayModeExisting')?.addEventListener('change', syncModalDayMode);
      document.getElementById('modalDayModeNew')?.addEventListener('change', syncModalDayMode);
      syncModalDayMode();

      // Expand / collapse all
      document.getElementById('btnExpandAll')?.addEventListener('click', () => {
        document.querySelectorAll('#daysAccordion .accordion-collapse').forEach(el => {
          bootstrap.Collapse.getOrCreateInstance(el).show();
        });
      });
      document.getElementById('btnCollapseAll')?.addEventListener('click', () => {
        document.querySelectorAll('#daysAccordion .accordion-collapse').forEach(el => {
          bootstrap.Collapse.getOrCreateInstance(el).hide();
        });
      });
    })();
  </script>
</body>
</html>
