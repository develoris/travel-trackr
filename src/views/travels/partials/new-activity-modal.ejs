<!-- Modal per creazione nuova attivita -->
<div class="modal fade" id="newActivityModal" tabindex="-1" aria-labelledby="newActivityModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="newActivityModalLabel">Nuova attivita</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p class="text-muted small">Scegli una tappa esistente o creane una nuova. L'ordine e automatico in base all'ora di inizio.</p>
        <form action="/users/app/travels/<%= trip._id %>/stages" method="POST" id="newActivityForm" class="row g-3">
          <div class="col-12 col-md-8">
            <label class="form-label small text-muted mb-1">Titolo attivita</label>
            <input class="form-control" name="title" required />
          </div>
          <div class="col-12 col-md-4">
            <label class="form-label small text-muted mb-1">Tipo attivita</label>
            <select class="form-select" name="activityType">
              <option value="trek">Trek</option>
              <option value="visita">Visita</option>
              <option value="trasferimento">Trasferimento</option>
              <option value="food">Food</option>
              <option value="relax">Relax</option>
              <option value="outdoor">Outdoor</option>
              <option value="altro">Altro</option>
            </select>
          </div>
          <div class="col-12">
            <label class="form-label small text-muted mb-1">Dove inserirla</label>
            <div class="d-flex gap-4">
              <div class="form-check">
                <input class="form-check-input" type="radio" name="dayMode" id="modalDayModeExisting" value="existing" <%= (dayOptions && dayOptions.length > 0) ? 'checked' : '' %> />
                <label class="form-check-label" for="modalDayModeExisting">Tappa esistente</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="dayMode" id="modalDayModeNew" value="new" <%= (!dayOptions || dayOptions.length === 0) ? 'checked' : '' %> />
                <label class="form-check-label" for="modalDayModeNew">Nuova tappa</label>
              </div>
            </div>
          </div>
          <div class="col-12 col-md-6" id="modalExistingDayWrap">
            <label class="form-label small text-muted mb-1">Tappa esistente</label>
            <select class="form-select" name="existingDayNumber">
              <option value="">Seleziona tappa</option>
              <% (dayOptions || []).forEach((dayNumber) => { %>
                <option value="<%= dayNumber %>">Tappa <%= dayNumber %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-12 col-md-6" id="modalNewDayWrap">
            <label class="form-label small text-muted mb-1">Numero nuova tappa</label>
            <input class="form-control" type="number" min="1" step="1" name="newDayNumber" placeholder="Es. 3" />
          </div>
          <div class="col-12 col-md-6">
            <label class="form-label small text-muted mb-1">Orario inizio (opzionale)</label>
            <input class="form-control" type="time" name="startTime" />
          </div>
          <div class="col-12 col-md-6">
            <label class="form-label small text-muted mb-1">Luogo</label>
            <input class="form-control" name="location" />
          </div>
          <div class="col-12">
            <label class="form-label small text-muted mb-1">Descrizione</label>
            <textarea class="form-control" name="description" rows="3"></textarea>
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annulla</button>
        <button type="submit" form="newActivityForm" class="btn btn-dark">Aggiungi attivita</button>
      </div>
    </div>
  </div>
</div>
