<!DOCTYPE html>
<html lang="it">
<head>
  <%- include("../partials/head", { title: "I miei viaggi" }) %>
</head>
<body class="d-flex flex-column min-vh-100">
  <%- include("../partials/navbar", { user }) %>

  <main class="flex-grow-1 py-3 py-md-5">
    <div class="container">
      <%- include("../partials/flash") %>
      <% const statusLabels = { planned: 'Pianificato', ongoing: 'In corso', completed: 'Completato', cancelled: 'Annullato' }; %>
      <% const categoryLabels = { escursione: 'Escursione', trekking: 'Trekking', visita: 'Visita', vacanza: 'Vacanza', roadtrip: 'Road trip', altro: 'Altro' }; %>

      <!-- Header compatto: niente hero pieno per ridurre lo spazio occupato -->
      <div class="card mb-4">
        <div class="card-body d-flex flex-column flex-sm-row justify-content-between align-items-start gap-3">
          <div>
            <h1 class="h3 fw-bold mb-2">I tuoi viaggi</h1>
            <p class="text-muted mb-0">Filtra, ordina e sfoglia senza caos anche con tanti viaggi.</p>
          </div>
          <a href="/users/app/travels/new" class="btn btn-dark fw-semibold mobile-btn-block text-sm-nowrap">
            <i class="bi bi-plus-lg me-1"></i>Nuovo viaggio
          </a>
        </div>
      </div>

      <div class="card mb-4">
        <div class="card-body">
          <form method="GET" action="/users/app/travels" class="row g-2 align-items-end">
            <div class="col-12 col-md-3">
              <label class="form-label small text-muted mb-1">Stato</label>
              <select class="form-select" name="status">
                <option value="">Tutti</option>
                <% ['planned','ongoing','completed','cancelled'].forEach((s) => { %>
                  <option value="<%= s %>" <%= filters?.status === s ? 'selected' : '' %>><%= statusLabels[s] || s %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-12 col-md-3">
              <label class="form-label small text-muted mb-1">Categoria</label>
              <select class="form-select" name="category">
                <option value="">Tutte</option>
                <% ['escursione','trekking','visita','vacanza','roadtrip','altro'].forEach((c) => { %>
                  <option value="<%= c %>" <%= filters?.category === c ? 'selected' : '' %>><%= categoryLabels[c] || c %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-12 col-md-3">
              <label class="form-label small text-muted mb-1">Ordina per data</label>
              <select class="form-select" name="sort">
                <option value="startDateDesc" <%= filters?.sort === 'startDateDesc' ? 'selected' : '' %>>Più recenti prima</option>
                <option value="startDateAsc" <%= filters?.sort === 'startDateAsc' ? 'selected' : '' %>>Più vecchi prima</option>
              </select>
            </div>
            <div class="col-6 col-md-2">
              <label class="form-label small text-muted mb-1">Per pagina</label>
              <select class="form-select" name="limit">
                <% [6,9,12].forEach((n) => { %>
                  <option value="<%= n %>" <%= Number(pagination?.limit || 6) === n ? 'selected' : '' %>><%= n %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-12 col-md-1 d-grid">
              <button class="btn btn-dark" type="submit">Applica</button>
            </div>
          </form>
        </div>
      </div>

      <% if (!trips || trips.length === 0) { %>
        <div class="card text-center py-5">
          <div class="card-body">
            <i class="bi bi-map text-secondary" style="font-size:2.5rem;"></i>
            <h2 class="h5 mt-3">Nessun viaggio trovato</h2>
            <p class="text-muted mb-0">Prova a cambiare filtri o crea un nuovo viaggio.</p>
          </div>
        </div>
      <% } else { %>
        <div class="row g-3 g-md-4">
          <% trips.forEach((trip) => { %>
            <div class="col-12 col-md-6 col-xl-4">
              <div class="card h-100">
                <div class="card-body d-flex flex-column">
                  <div class="d-flex justify-content-between align-items-start mb-2">
                      <span class="badge text-bg-light text-uppercase"><%= categoryLabels[trip.category] || trip.category %></span>
                      <span class="badge text-bg-<%= trip.status === 'completed' ? 'success' : trip.status === 'ongoing' ? 'warning' : trip.status === 'cancelled' ? 'danger' : 'secondary' %>"><%= statusLabels[trip.status] || trip.status %></span>
                  </div>
                  <h2 class="h5 card-title mb-1"><%= trip.title %></h2>
                    <p class="text-muted small mb-2 text-truncate"><i class="bi bi-geo-alt me-1"></i><%= trip.locationSummary || 'Località da definire' %></p>
                  <p class="card-text small flex-grow-1 mb-3"><%= trip.description || 'Nessuna descrizione generale.' %></p>
                  <ul class="list-unstyled text-muted small mb-3">
                    <li><i class="bi bi-calendar-event me-1"></i><%= new Date(trip.startDate).toLocaleDateString('it-IT') %> - <%= new Date(trip.endDate).toLocaleDateString('it-IT') %></li>
                    <li><i class="bi bi-signpost me-1"></i><%= trip.stats?.daysCount || 0 %> giorni</li>
                    <li><i class="bi bi-list-check me-1"></i><%= trip.stats?.activitiesCount || 0 %> attività</li>
                    <li><i class="bi bi-cash-stack me-1"></i>EUR <%= Number(trip.stats?.totalSpent || 0).toFixed(2) %></li>
                  </ul>
                  <a href="/users/app/travels/<%= trip._id %>" class="btn btn-outline-dark btn-sm mt-auto">Apri dettaglio</a>
                </div>
              </div>
            </div>
          <% }) %>
        </div>

        <% if (pagination && pagination.totalPages > 1) { %>
          <nav aria-label="Paginazione viaggi" class="mt-4">
            <ul class="pagination pagination-sm mb-0 justify-content-center flex-wrap gap-1">
              <li class="page-item <%= pagination.hasPrev ? '' : 'disabled' %>">
                <a class="page-link" href="/users/app/travels?page=<%= pagination.page - 1 %>&limit=<%= pagination.limit %>&sort=<%= filters?.sort || 'startDateDesc' %>&status=<%= encodeURIComponent(filters?.status || '') %>&category=<%= encodeURIComponent(filters?.category || '') %>">Precedente</a>
              </li>
              <li class="page-item disabled">
                <span class="page-link">Pagina <%= pagination.page %> di <%= pagination.totalPages %></span>
              </li>
              <li class="page-item <%= pagination.hasNext ? '' : 'disabled' %>">
                <a class="page-link" href="/users/app/travels?page=<%= pagination.page + 1 %>&limit=<%= pagination.limit %>&sort=<%= filters?.sort || 'startDateDesc' %>&status=<%= encodeURIComponent(filters?.status || '') %>&category=<%= encodeURIComponent(filters?.category || '') %>">Successiva</a>
              </li>
            </ul>
          </nav>
        <% } %>
      <% } %>
    </div>
  </main>

  <footer class="text-center text-muted py-3 small border-top mt-auto">
    &copy; <%= new Date().getFullYear() %> Travel Trackr
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
