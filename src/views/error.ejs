<!DOCTYPE html>
<html lang="it">
<head>
  <%- include("partials/head", { title: "Errore" }) %>
</head>
<body class="d-flex flex-column min-vh-100">
  <% const bp = basePath || ''; %>
  <%- include("partials/navbar", { user: null }) %>

  <main class="flex-grow-1 d-flex align-items-center py-5">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
          <div class="card shadow-sm border-0 text-center">
            <div class="card-body p-5">
              <div class="display-6 text-danger mb-3">
                <i class="bi bi-exclamation-octagon"></i>
              </div>
              <h1 class="h4 fw-bold mb-2">Oops, qualcosa e andato storto</h1>
              <p class="text-muted mb-3"><%= message %></p>
              <p class="small text-muted mb-4">
                Codice: <strong><%= status %></strong> · Request ID: <strong><%= requestId %></strong>
              </p>
              <a href="<%= bp %>/users/app" class="btn btn-primary">Torna alla home</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
