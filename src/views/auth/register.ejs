<!DOCTYPE html>
<html lang="it">
<head>
  <%- include("../partials/head", { title: "Registrazione disabilitata" }) %>
</head>
<body class="d-flex flex-column min-vh-100">
  <% const bp = basePath || ''; %>

  <%- include("../partials/navbar", { user: null }) %>

  <main class="flex-grow-1 d-flex align-items-center py-5">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
          <div class="card border-0 shadow-sm">
            <div class="card-body p-4 p-md-5 text-center">
              <i class="bi bi-shield-lock text-primary" style="font-size: 2.5rem;"></i>
              <h1 class="h4 mt-3 mb-2">Registrazione non disponibile</h1>
              <p class="text-muted mb-4">
                Gli account vengono creati solo da un amministratore con password temporanea.
              </p>
              <a href="<%= bp %>/users/app/login" class="btn btn-primary">Vai al login</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <footer class="text-center text-muted py-3 small border-top">
    &copy; <%= new Date().getFullYear() %> Travel Trackr
  </footer>
</body>
</html>
