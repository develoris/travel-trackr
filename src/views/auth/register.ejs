<!DOCTYPE html>
<html lang="it">
<head>
  <%- include("../partials/head", { title: "Registrati" }) %>
</head>
<body class="d-flex flex-column min-vh-100">

  <%- include("../partials/navbar", { user: null }) %>

  <main class="flex-grow-1 d-flex align-items-center py-5">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12 col-sm-10 col-md-7 col-lg-5 col-xl-4">

          <div class="text-center mb-4">
            <i class="bi bi-person-plus text-primary" style="font-size: 2.5rem;"></i>
            <h1 class="h4 mt-2 fw-bold">Crea il tuo account</h1>
            <p class="text-muted small">Inizia a tracciare i tuoi viaggi</p>
          </div>

          <%- include("../partials/flash") %>

          <div class="card shadow-sm border-0">
            <div class="card-body p-4">
              <form action="/users/app/register" method="POST" novalidate>
                <div class="mb-3">
                  <label for="name" class="form-label fw-semibold">Nome <span class="text-muted fw-normal">(opzionale)</span></label>
                  <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-person"></i></span>
                    <input
                      type="text"
                      class="form-control"
                      id="name"
                      name="name"
                      placeholder="Mario Rossi"
                      value="<%= typeof formData !== 'undefined' ? formData.name : '' %>"
                      autofocus
                    />
                  </div>
                </div>
                <div class="mb-3">
                  <label for="email" class="form-label fw-semibold">Email</label>
                  <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                    <input
                      type="email"
                      class="form-control"
                      id="email"
                      name="email"
                      placeholder="mario@example.com"
                      value="<%= typeof formData !== 'undefined' ? formData.email : '' %>"
                      required
                    />
                  </div>
                </div>
                <div class="mb-3">
                  <label for="password" class="form-label fw-semibold">Password</label>
                  <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-lock"></i></span>
                    <input
                      type="password"
                      class="form-control"
                      id="password"
                      name="password"
                      placeholder="Minimo 8 caratteri"
                      required
                    />
                  </div>
                </div>
                <div class="mb-4">
                  <label for="confirmPassword" class="form-label fw-semibold">Conferma password</label>
                  <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                    <input
                      type="password"
                      class="form-control"
                      id="confirmPassword"
                      name="confirmPassword"
                      placeholder="Ripeti la password"
                      required
                    />
                  </div>
                </div>
                <div class="d-grid">
                  <button type="submit" class="btn btn-primary">
                    <i class="bi bi-person-check me-1"></i>Registrati
                  </button>
                </div>
              </form>
            </div>
          </div>

          <p class="text-center mt-4 text-muted small">
            Hai già un account?
            <a href="/users/app/login" class="text-decoration-none fw-semibold">Accedi</a>
          </p>

        </div>
      </div>
    </div>
  </main>

  <footer class="text-center text-muted py-3 small border-top">
    &copy; <%= new Date().getFullYear() %> Travel Trackr
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
