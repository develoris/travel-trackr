<!DOCTYPE html>
<html lang="it">
<head>
  <%- include("partials/head", { title: "I miei viaggi" }) %>
</head>
<body class="d-flex flex-column min-vh-100">

  <%- include("partials/navbar", { user }) %>

  <main class="flex-grow-1 py-5">
    <div class="container">

      <%- include("partials/flash") %>

      <!-- Header sezione -->
      <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
          <h2 class="fw-bold mb-0">
            <i class="bi bi-backpack2 text-primary me-2"></i>I miei viaggi
          </h2>
          <p class="text-muted small mb-0 mt-1">Tutti i tuoi viaggi in un posto solo</p>
        </div>
        <button
          class="btn btn-primary"
          disabled
          data-bs-toggle="tooltip"
          data-bs-placement="left"
          title="Prossimamente disponibile"
        >
          <i class="bi bi-plus-lg me-1"></i>Nuovo viaggio
        </button>
      </div>

      <!-- Placeholder vuoto -->
      <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
          <div class="card border-0 shadow-sm text-center py-5">
            <div class="card-body">
              <i class="bi bi-map text-muted" style="font-size: 4rem; opacity: 0.3;"></i>
              <h4 class="mt-3 fw-semibold text-muted">Nessun viaggio ancora</h4>
              <p class="text-muted small mb-4">
                Presto potrai aggiungere, organizzare e tracciare tutti i tuoi viaggi, giorni e spese.
              </p>
              <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill">
                <i class="bi bi-clock-history me-1"></i>Funzionalità in arrivo
              </span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </main>

  <footer class="text-center text-muted py-3 small border-top mt-auto">
    &copy; <%= new Date().getFullYear() %> Travel Trackr
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Inizializza tooltip Bootstrap
    document.querySelectorAll("[data-bs-toggle='tooltip']").forEach((el) => {
      new bootstrap.Tooltip(el);
    });
  </script>
</body>
</html>
