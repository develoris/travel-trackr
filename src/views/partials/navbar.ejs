<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
  <div class="container">
    <% const currentPathValue = typeof currentPath !== 'undefined' ? currentPath : ''; %>
    <% const isActive = (prefix) => currentPathValue === prefix || currentPathValue.startsWith(`${prefix}/`); %>

    <!-- Logo -->
    <a class="navbar-brand d-flex align-items-center gap-2" href="/users/app">
      <i class="bi bi-map fs-4 text-primary"></i>
      <span>Travel Trackr</span>
    </a>

    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#mainNav"
      aria-controls="mainNav"
      aria-expanded="false"
      aria-label="Toggle navigation"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="mainNav">
      <% if (user) { %>
        <!-- Utente loggato -->
        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
          <li class="nav-item">
            <a class="nav-link <%= isActive('/users/app/travels') ? 'active' : '' %>" href="/users/app/travels"><i class="bi bi-backpack2 me-1"></i>I miei viaggi</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= currentPathValue === '/users/app/travels/new' ? 'active' : '' %>" href="/users/app/travels/new"><i class="bi bi-plus-circle me-1"></i>Nuovo viaggio</a>
          </li>
          <li class="nav-item">
            <a class="nav-link disabled text-muted" href="#"
              data-bs-toggle="tooltip" title="Prossimamente">
              <i class="bi bi-map me-1"></i>Esplora
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link disabled text-muted" href="#"
              data-bs-toggle="tooltip" title="Prossimamente">
              <i class="bi bi-bar-chart me-1"></i>Statistiche
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= isActive('/users/app/profile') ? 'active' : '' %>" href="/users/app/profile"><i class="bi bi-person-gear me-1"></i>Mio profilo</a>
          </li>
          <% if (user.role === 'admin') { %>
            <li class="nav-item">
              <a class="nav-link <%= isActive('/users/app/admin/users') ? 'active' : '' %>" href="/users/app/admin/users"><i class="bi bi-people me-1"></i>Gestione utenti</a>
            </li>
          <% } %>
        </ul>
        <ul class="navbar-nav ms-auto align-items-center gap-2">
          <li class="nav-item">
            <span class="navbar-text text-light">
              <i class="bi bi-person-circle me-1"></i><%= user.name || user.email %>
            </span>
          </li>
          <li class="nav-item">
            <form action="/users/app/logout" method="POST" class="d-inline">
              <button type="submit" class="btn btn-outline-light btn-sm">
                <i class="bi bi-box-arrow-right me-1"></i>Logout
              </button>
            </form>
          </li>
        </ul>
      <% } else { %>
        <!-- Utente non loggato -->
        <ul class="navbar-nav ms-auto gap-2">
          <li class="nav-item">
            <a class="nav-link <%= isActive('/users/app/login') ? 'active' : '' %>" href="/users/app/login"><i class="bi bi-box-arrow-in-right me-1"></i>Accedi</a>
          </li>
        </ul>
      <% } %>
    </div>

  </div>
</nav>
