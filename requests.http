@baseUrl = http://localhost:3000
@contentType = application/json

# Copia i token dalle risposte di login qui sotto per usarli nelle richieste successive
@accessToken = <incolla_access_token>
@refreshToken = <incolla_refresh_token>
@userId = <incolla_user_id>
@tripId = <incolla_trip_id>
@stageId = <incolla_stage_id>


### ──────────────────────────────────────────
###  AUTH
### ──────────────────────────────────────────

### [SIGNIN] Registra un nuovo utente
POST {{baseUrl}}/users/signin
Content-Type: {{contentType}}

{
  "email": "mario@example.com",
  "password": "password123",
  "name": "Mario Rossi"
}

### [LOGIN] Accedi con le credenziali → copia accessToken e refreshToken dalla risposta
POST {{baseUrl}}/users/login
Content-Type: {{contentType}}

{
  "email": "mario@example.com",
  "password": "password123"
}

### [REFRESH] Ruota i token (il refreshToken viene letto dal cookie tt.rt)
POST {{baseUrl}}/users/refresh

### [LOGOUT] Revoca la sessione (il refreshToken viene letto dal cookie tt.rt)
POST {{baseUrl}}/users/logout


### ──────────────────────────────────────────
###  USERS – CRUD
### ──────────────────────────────────────────

### [GET ALL] Lista tutti gli utenti
GET {{baseUrl}}/users

### [GET ONE] Ottieni un singolo utente per ID
GET {{baseUrl}}/users/{{userId}}

### [POST] Crea un utente direttamente (bypassa signin)
POST {{baseUrl}}/users
Content-Type: {{contentType}}

{
  "email": "admin@example.com",
  "passwordHash": "password123",
  "name": "Admin",
  "role": "admin"
}

### [PATCH] Aggiorna nome di un utente
PATCH {{baseUrl}}/users/{{userId}}
Content-Type: {{contentType}}

{
  "name": "Mario Aggiornato"
}

### [PATCH] Aggiorna email di un utente
PATCH {{baseUrl}}/users/{{userId}}
Content-Type: {{contentType}}

{
  "email": "mario.nuovo@example.com"
}

### [DELETE] Elimina un utente
DELETE {{baseUrl}}/users/{{userId}}


### ──────────────────────────────────────────
###  TRAVELS – API (Bearer Token)
### ──────────────────────────────────────────

### [GET ALL] Lista viaggi del mio utente
GET {{baseUrl}}/users/travels
Authorization: Bearer {{accessToken}}

### [POST] Crea viaggio
POST {{baseUrl}}/users/travels
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "title": "Weekend in Appennino",
  "category": "trekking",
  "status": "planned",
  "startDate": "2026-05-09",
  "endDate": "2026-05-10",
  "locationSummary": "Corno alle Scale",
  "description": "Due giorni tra sentieri e rifugio"
}

### [GET ONE] Dettaglio viaggio
GET {{baseUrl}}/users/travels/{{tripId}}
Authorization: Bearer {{accessToken}}

### [POST] Aggiungi tappa al viaggio
POST {{baseUrl}}/users/travels/{{tripId}}/stages
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "title": "Sentiero del Corno",
  "kind": "trek",
  "location": "Corno alle Scale",
  "description": "Tappa principale"
}

### [POST] Aggiungi spesa a una tappa
POST {{baseUrl}}/users/travels/{{tripId}}/stages/{{stageId}}/expenses
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "title": "Pranzo rifugio",
  "amount": 22.5,
  "category": "cibo"
}

### [PATCH] Aggiorna stato viaggio
PATCH {{baseUrl}}/users/travels/{{tripId}}
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "status": "completed"
}

### [DELETE] Elimina viaggio
DELETE {{baseUrl}}/users/travels/{{tripId}}
Authorization: Bearer {{accessToken}}
